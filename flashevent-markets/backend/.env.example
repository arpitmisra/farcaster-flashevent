# FlashEvent Markets - Backend Server Environment Variables

# Server
PORT=3001
NODE_ENV=development

# Database
MONGODB_URI=mongodb://localhost:27017/flashevent
REDIS_URL=redis://localhost:6379

# Authentication
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# Blockchain
RPC_URL=https://monad-testnet.g.alchemy.com/v2/f6Q2jX1N6pG4yztkh_TK5
CHAIN_ID=10143
RESOLVER_PRIVATE_KEY=your_resolver_private_key_here

# Contracts
MARKET_FACTORY_ADDRESS=

# Farcaster / Neynar
NEYNAR_API_KEY=your_neynar_api_key_here
NEYNAR_HUB_URL=https://hub-api.neynar.com

# x402 Micropayments
X402_PAYMENT_RECIPIENT=your_payment_recipient_address
X402_ENABLED=true

# Price Feeds
COINGECKO_API_KEY=
PYTH_ENDPOINT=https://hermes.pyth.network

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info
