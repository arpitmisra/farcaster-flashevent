# x402 Environment Configuration
# Copy this file to .env and fill in your values

# ===========================================
# REQUIRED CONFIGURATION
# ===========================================

# Payment recipient address (your wallet that receives payments)
X402_RECIPIENT=0xBb689Fd2A92b6EB905e56C3726Bf090fA2D3a6a4

# ===========================================
# NETWORK CONFIGURATION
# ===========================================

# Network name (monad-testnet, monad-mainnet, sepolia, base-sepolia)
NETWORK=monad-testnet

# Chain ID (10143 for Monad testnet)
CHAIN_ID=10143

# RPC URL for the network
MONAD_RPC_URL=https://monad-testnet.g.alchemy.com/v2/f6Q2jX1N6pG4yztkh_TK5

# ===========================================
# OPTIONAL CONFIGURATION
# ===========================================

# Verify payer balance before accepting payment (true/false)
# Set to false for faster processing but less security
X402_VERIFY_BALANCE=true

# Payment timeout in seconds (default: 300 = 5 minutes)
X402_PAYMENT_TIMEOUT=300

# Minimum payment amount in ETH
X402_MIN_PAYMENT=0.0001

# Maximum payment amount in ETH
X402_MAX_PAYMENT=10

# ===========================================
# REDIS CONFIGURATION (for production)
# ===========================================

# Redis URL for nonce tracking and caching
REDIS_URL=redis://localhost:6379

# ===========================================
# DEVELOPMENT OPTIONS
# ===========================================

# Skip payment verification in development (NOT for production!)
# X402_SKIP_VERIFICATION=false

# Enable debug logging
# X402_DEBUG=false
