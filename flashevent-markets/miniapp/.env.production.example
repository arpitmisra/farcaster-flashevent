# FlashEvent Markets - Frontend Production Environment Variables
# Copy these to Vercel Dashboard > Settings > Environment Variables

# App URL (your Vercel frontend URL)
NEXT_PUBLIC_APP_URL=https://your-frontend.vercel.app

# Backend API URL (your Vercel backend URL)
NEXT_PUBLIC_API_URL=https://your-backend.vercel.app/api

# WebSocket URL (leave empty for serverless - WS not supported on Vercel)
NEXT_PUBLIC_WS_URL=

# Privy App ID
NEXT_PUBLIC_PRIVY_APP_ID=cmkslvpv000ghjs0dzwmyvkm0

# Monad Network
NEXT_PUBLIC_MONAD_RPC_URL=https://monad-testnet.g.alchemy.com/v2/f6Q2jX1N6pG4yztkh_TK5
NEXT_PUBLIC_CHAIN_ID=10143

# Smart Contracts
NEXT_PUBLIC_MARKET_FACTORY_ADDRESS=0x4a0F0d703e061c5F4fD0C8DDafDcBd2d45D36007
NEXT_PUBLIC_PLATFORM_TREASURY=0x34255f25d1bc2e7f24351119a9ea3606d9f3fe18

