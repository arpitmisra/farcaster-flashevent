# FlashEvent Markets - Mobile App Environment Variables

# App
EXPO_PUBLIC_APP_NAME=FlashEvent Markets
EXPO_PUBLIC_ENV=development

# API
EXPO_PUBLIC_API_URL=http://localhost:3001/api
EXPO_PUBLIC_FRAMES_URL=http://localhost:3002

# Blockchain (Monad Testnet)
EXPO_PUBLIC_CHAIN_ID=10143
EXPO_PUBLIC_RPC_URL=https://monad-testnet.g.alchemy.com/v2/f6Q2jX1N6pG4yztkh_TK5
EXPO_PUBLIC_EXPLORER_URL=https://testnet.monadexplorer.com

# Farcaster
EXPO_PUBLIC_NEYNAR_API_KEY=your_neynar_api_key_here
EXPO_PUBLIC_NEYNAR_CLIENT_ID=your_neynar_client_id_here
EXPO_PUBLIC_FARCASTER_REDIRECT_URL=flashevent://auth/callback

# Contracts (deployed addresses on Monad Testnet)
EXPO_PUBLIC_MARKET_FACTORY_ADDRESS=0x4a0F0d703e061c5F4fD0C8DDafDcBd2d45D36007

# x402 Micropayments
EXPO_PUBLIC_X402_ENABLED=true
EXPO_PUBLIC_PAYMENT_RECIPIENT=
